{
  "name": "@zentauri-ui/zentauri-components",
  "version": "1.3.0",
  "description": "A UI component library built with React and Tailwind CSS",
  "license": "MIT",
  "files": ["dist"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./ui/*": {
      "types": "./dist/ui/*.d.ts",
      "import": "./dist/ui/*.mjs",
      "require": "./dist/ui/*.js"
    },
    "./ui/*/animated": {
      "types": "./dist/ui/*/animated.d.ts",
      "import": "./dist/ui/*/animated.mjs",
      "require": "./dist/ui/*/animated.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.mjs",
      "require": "./dist/hooks/*.js"
    }
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 tsup --watch",
    "build": "NODE_OPTIONS=--max-old-space-size=2048 tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "class-variance-authority": "*",
    "clsx": "*",
    "tailwind-merge": "*",
    "framer-motion": "*",
    "react-icons": "*"
  },
  "peerDependenciesMeta": {
    "framer-motion": { "optional": true },
    "react-icons": { "optional": true }
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^26.1.0",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "tsup": "^8.5.1"
  }
}